# 复制本文件为 .env 并填写，不要提交 .env 到 Git

# 数据库（可选，默认 SQLite）
# DATABASE_URL=sqlite:///./mindmap.db

# 使用自己的大模型（可选）：不填则用内置规则，不调用任何 API
# 支持所有 OpenAI 兼容接口（OpenAI / StepFun / DeepSeek / 通义 等）
# AI_API_BASE=https://api.openai.com/v1
# AI_API_KEY=sk-你的key
# AI_MODEL=gpt-4o-mini

# 取名用极速、内容用推理（可选）：不填则全部用 AI_MODEL
# AI_MODEL_FAST=step-2-mini
# AI_MODEL_REASONING=step-2

# 示例：StepFun（单模型时只填 AI_MODEL）
# AI_API_BASE=https://api.stepfun.com/v1
# AI_API_KEY=你的stepfun-key
# AI_MODEL=step-2-mini

# 示例：DeepSeek
# AI_API_BASE=https://api.deepseek.com/v1
# AI_API_KEY=你的deepseek-key
# AI_MODEL=deepseek-chat

# 多模型分担压力（可选）：再配一组 Base+Key，请求会轮询到不同端点，减轻 429
# AI_API_BASE_2=https://api.deepseek.com/v1
# AI_API_KEY_2=你的另一个key
# 可再配第三组：AI_API_BASE_3、AI_API_KEY_3

# 熵增·网页搜索（可选）：配置后节点右键「网页」可搜最相关例子；超级 Agent 也会用网页摘要增强回答
# 不配置时超级 Agent 仍会运行，仅不会注入网页摘要；申请 Key：https://serper.dev
# SEARCH_API_KEY=你的serper-key
